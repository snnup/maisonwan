# Maison Wan - Configurações de Servidor

# Ativar mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Define o diretório base — ajuste se mudar o nome da pasta
    RewriteBase /
    
    # Remove trailing slash (exceto pasta raiz)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ $1 [L,R=301]
    
    # Redireciona URLs sem extensão para .php (ex: /fashion → /fashion.php)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/$1.php -f
    RewriteRule ^([^.]+)$ $1.php [L]
</IfModule>

# Página de erro 404 personalizada
ErrorDocument 404 /404.php

# Bloquear acesso a arquivos sensíveis
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

<Files "config-404.php">
    Order allow,deny
    Deny from all
</Files>

# Compressão de conteúdo
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache de navegador
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Imagens
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    
    # CSS e JS
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    
    # Fontes
    ExpiresByType font/ttf "access plus 30 days"
    ExpiresByType font/woff "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
    
    # HTML
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Cabeçalhos de segurança
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
